{
    "name": "codraw/validator",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "draw",
        "validator",
        "symfony"
    ],
    "authors": [
        {
            "name": "Martin Poirier Theoret",
            "email": "mpoiriert@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/validator": "^6.4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3 || ^12.0",
        "doctrine/orm": "^2.10 || ^3.0",
        "doctrine/persistence": "^2.2 || ^3.0",
        "codraw/dependency-injection": "^0.39"
    },
    "suggest": {
        "codraw/dependency-injection": "To use the ValidatorIntegration",
        "doctrine/orm": "To use the ValueIsNotUsedValidator",
        "doctrine/persistence": "To use the ValueIsNotUsedValidator"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\Validator\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/validator": "self.version"
    }
}
